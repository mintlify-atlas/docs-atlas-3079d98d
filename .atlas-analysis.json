  "keyFeatures": [
    "JWT-based authentication with OTP email verification",
    "Real-time driver location tracking via WebSocket/STOMP",
    "Ride booking, status management, and cancellation",
    "Stripe Checkout integration for ride payments",
    "Role-based dashboards for riders and drivers",
    "In-app notification center with ride and payment alerts",
    "Ride history with feedback and rating system",
    "Nearby driver discovery using geolocation cache"
  ],
